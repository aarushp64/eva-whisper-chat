# ==========================================
# EVA Whisper Chat — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/eva-assistant
DATABASE_URI=sqlite:///eva.db

# ── Auth ──
SECRET_KEY=change_this_to_a_random_secure_string
JWT_SECRET_KEY=change_this_to_a_different_random_string

# ── Client ──
CLIENT_URL=http://localhost:5173

# ── Ollama (Local) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=qwen3.5:9b

# ── Groq (Cloud) ──
# Get your key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# ── OpenRouter (Cloud) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen2.5-coder-7b-instruct

# ── Anthropic (Premium) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Agent ──
AGENT_MODE=full
MEMORY_SIZE=20

# ── Whisper (Speech-to-Text) ──
WHISPER_MODEL=base
