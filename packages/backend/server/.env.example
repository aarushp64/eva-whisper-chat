# ==========================================
# EVA Whisper Chat — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Security ──
SECRET_KEY=change_this_to_a_random_secure_string
JWT_SECRET_KEY=change_this_to_a_different_random_string

# ── Database ──
DATABASE_URI=sqlite:///eva.db
MONGODB_URI=mongodb://localhost:27017/eva-assistant

# ── Client ──
CLIENT_URL=http://localhost:5173

# ── Groq (Cloud — Fast inference) ──
# Get your key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# ── Ollama (Local — Private, no key needed) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=qwen3.5:9b

# ── Agent ──
AGENT_MODE=full
MEMORY_SIZE=20

# ── Whisper (Speech-to-Text) ──
WHISPER_MODEL=base
